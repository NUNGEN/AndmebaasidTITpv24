--2. reservation
CREATE TABLE reservation(
reservationID int PRIMARY KEY identity (1,1),
date_in DATE,
date_out DATE,
made_by varchar(20),
guestID int,
FOREIGN KEY (guestID) REFERENCES guest(guestID));

SELECT * FROM reservation;

